{
  "version": 2,
  "functions": {
    "api/stats.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/stats",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "image/svg+xml" }
      ]
    }
  ]
}
